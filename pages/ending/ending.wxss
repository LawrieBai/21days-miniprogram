/* ==================== 主容器 ==================== */
.ending-container {
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: linear-gradient(180deg, #ffecd2 0%, #fcb69f 100%);
  padding: 30rpx 30rpx 60rpx;
  box-sizing: border-box;
}

/* ==================== 伴侣形象区 ==================== */
.companion-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 30rpx 0 20rpx;
}

.companion-avatar {
  width: 180rpx;
  height: 210rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 12rpx;
}

.avatar-face {
  width: 140rpx;
  height: 164rpx;
  position: relative;
  overflow: hidden;
  box-shadow: 0 8rpx 30rpx rgba(0, 0, 0, 0.1);
}

/* 肤色 */
.skin-0 { background: #FFE4C4; }
.skin-1 { background: #FFDAB9; }
.skin-2 { background: #D2A679; }

/* 脸型 */
.face-0 { border-radius: 50%; }
.face-1 { border-radius: 45% 45% 50% 50%; }
.face-2 { border-radius: 20%; }

/* 发型 */
.hair {
  position: absolute;
  top: -10rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 150rpx;
  height: 80rpx;
  background: #2c2c2c;
  border-radius: 50% 50% 0 0;
  z-index: 2;
}

.hair-0 {
  height: 56rpx;
  width: 136rpx;
  border-radius: 50% 50% 20% 20%;
}

.hair-1 {
  height: 90rpx;
  width: 156rpx;
  border-radius: 50% 50% 10% 10%;
}

.hair-2 {
  height: 120rpx;
  width: 162rpx;
  border-radius: 50% 50% 30% 30%;
  top: -20rpx;
}

/* 眼睛 */
.eyes {
  position: absolute;
  top: 64rpx;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 28rpx;
  z-index: 1;
}

.eye {
  width: 14rpx;
  height: 14rpx;
  background: #333;
  border-radius: 50%;
}

.eyes-0 .eye {
  width: 20rpx;
  height: 20rpx;
}

.eyes-1 .eye {
  width: 16rpx;
  height: 12rpx;
  border-radius: 50%;
}

.eyes-2 .eye {
  width: 20rpx;
  height: 9rpx;
  border-radius: 40%;
}

/* 嘴巴 */
.mouth {
  position: absolute;
  bottom: 34rpx;
  left: 50%;
  transform: translateX(-50%);
  width: 20rpx;
  height: 10rpx;
  z-index: 1;
}

.mouth-0 {
  border-bottom: 3rpx solid #e88;
  border-radius: 0 0 50% 50%;
  width: 26rpx;
  height: 13rpx;
}

.mouth-1 {
  background: #e88;
  border-radius: 50%;
  width: 18rpx;
  height: 16rpx;
}

.mouth-2 {
  border-bottom: 3rpx solid #d88;
  width: 24rpx;
  height: 0;
}

.companion-name {
  font-size: 32rpx;
  color: #555;
  font-weight: 600;
}

/* ==================== 通用卡片 ==================== */
.card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 36rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 24rpx;
  text-align: center;
}

/* ==================== 亲密度卡片 ==================== */
.intimacy-card {
  text-align: center;
}

.intimacy-header {
  margin-bottom: 16rpx;
}

.intimacy-value {
  font-size: 48rpx;
  font-weight: 800;
  color: #ee5a24;
}

.progress-bar {
  width: 100%;
  height: 20rpx;
  background: rgba(0, 0, 0, 0.06);
  border-radius: 10rpx;
  overflow: hidden;
}

.progress-fill {
  height: 100%;
  border-radius: 10rpx;
  transition: width 1s ease;
}

.intimacy-fill {
  background: linear-gradient(90deg, #ff6b6b, #ee5a24);
}

.intimacy-percent {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-top: 12rpx;
}

/* ==================== 告别诗卡片 ==================== */
.poem-card {
  background: linear-gradient(135deg, #fff5f5 0%, #ffe0e0 100%);
  border: none;
  box-shadow: 0 4rpx 20rpx rgba(255, 150, 150, 0.15);
}

.poem-content {
  min-height: 300rpx;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.poem-text {
  font-size: 30rpx;
  color: #555;
  line-height: 2;
  white-space: pre-wrap;
  text-align: center;
}

.poem-cursor {
  font-size: 30rpx;
  color: #ee5a24;
  animation: cursorBlink 0.8s ease-in-out infinite;
  margin-left: 2rpx;
}

@keyframes cursorBlink {
  0%, 100% { opacity: 1; }
  50% { opacity: 0; }
}

/* ==================== 留言卡片 ==================== */
.message-input {
  width: 100%;
  height: 240rpx;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  line-height: 1.6;
  box-sizing: border-box;
  border: 2rpx solid #eee;
}

.message-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 16rpx;
}

.message-counter {
  font-size: 24rpx;
  color: #999;
}

.submit-btn {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  padding: 16rpx 48rpx;
  border-radius: 50rpx;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.3);
}

.submit-btn:active {
  transform: scale(0.96);
}

.message-submitted {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submitted-text {
  font-size: 30rpx;
  color: #00b894;
  font-weight: 600;
  margin-bottom: 20rpx;
}

.submitted-content {
  width: 100%;
  background: #f7f7f7;
  border-radius: 16rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #555;
  line-height: 1.6;
  box-sizing: border-box;
}

/* ==================== 导出按钮 ==================== */
.export-section {
  width: 100%;
  margin-bottom: 24rpx;
}

.export-btn {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  text-align: center;
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  border-radius: 50rpx;
  box-shadow: 0 6rpx 24rpx rgba(102, 126, 234, 0.4);
}

.export-btn:active {
  transform: scale(0.97);
}

/* ==================== 重新开始按钮 ==================== */
.restart-section {
  width: 100%;
  margin-bottom: 40rpx;
}

.restart-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  background: rgba(0, 0, 0, 0.05);
  color: #999;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 50rpx;
}

.restart-btn:active {
  background: rgba(0, 0, 0, 0.1);
  transform: scale(0.97);
}

/* ==================== 支付确认弹窗 ==================== */
.pay-modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: center;
  justify-content: center;
}

.pay-modal {
  width: 600rpx;
  background: #fff;
  border-radius: 30rpx;
  padding: 48rpx 40rpx 36rpx;
  box-shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.2);
}

.pay-modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: #333;
  text-align: center;
  margin-bottom: 24rpx;
}

.pay-modal-desc {
  font-size: 28rpx;
  color: #666;
  line-height: 1.6;
  text-align: center;
  margin-bottom: 32rpx;
}

.pay-modal-amount {
  font-size: 48rpx;
  font-weight: 800;
  color: #ee5a24;
  text-align: center;
  margin-bottom: 40rpx;
}

.pay-modal-buttons {
  display: flex;
  gap: 24rpx;
}

.pay-btn {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
  border-radius: 50rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.pay-btn-cancel {
  background: #f0f0f0;
  color: #666;
}

.pay-btn-cancel:active {
  background: #e0e0e0;
}

.pay-btn-confirm {
  background: linear-gradient(135deg, #667eea, #764ba2);
  color: #fff;
  box-shadow: 0 4rpx 16rpx rgba(102, 126, 234, 0.4);
}

.pay-btn-confirm:active {
  transform: scale(0.96);
}
