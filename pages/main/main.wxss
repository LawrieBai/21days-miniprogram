.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
}

/* 设置流程 */
.setup-container {
  padding: 60rpx 40rpx;
}

.step-title {
  font-size: 48rpx;
  font-weight: bold;
  color: #fff;
  text-align: center;
  margin-bottom: 80rpx;
}

.gender-select {
  display: flex;
  justify-content: center;
  gap: 60rpx;
  margin-bottom: 80rpx;
}

.gender-option {
  width: 240rpx;
  height: 240rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 24rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 20rpx;
  box-shadow: 0 8rpx 20rpx rgba(0,0,0,0.1);
}

.gender-option.selected {
  background: #667eea;
  color: #fff;
}

.gender-icon {
  font-size: 80rpx;
}

.name-input {
  background: rgba(255,255,255,0.9);
  border-radius: 16rpx;
  padding: 30rpx;
  font-size: 32rpx;
  margin-bottom: 80rpx;
}

.setup-buttons {
  display: flex;
  justify-content: center;
  gap: 40rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: none;
}

.btn-secondary {
  background: rgba(255,255,255,0.5);
  color: #666;
  padding: 30rpx 60rpx;
  border-radius: 50rpx;
  font-size: 32rpx;
  border: none;
}

/* 主游戏界面 */
.main-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
}

.header {
  display: flex;
  justify-content: space-between;
  padding: 30rpx;
  background: rgba(255,255,255,0.9);
}

.day-info {
  font-size: 32rpx;
  color: #667eea;
  font-weight: bold;
}

.intimacy {
  font-size: 28rpx;
  color: #e74c3c;
}

.companion-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.companion-avatar {
  font-size: 120rpx;
  margin-bottom: 20rpx;
}

.companion-name {
  font-size: 36rpx;
  color: #fff;
  font-weight: bold;
}

.chat-area {
  flex: 1;
  background: rgba(255,255,255,0.95);
  margin: 0 30rpx;
  border-radius: 24rpx;
  padding: 30rpx;
}

.message {
  margin-bottom: 30rpx;
  max-width: 80%;
}

.message.user {
  margin-left: auto;
}

.message.ai {
  margin-right: auto;
}

.message-content {
  padding: 20rpx 30rpx;
  border-radius: 20rpx;
  font-size: 30rpx;
  line-height: 1.5;
}

.message.user .message-content {
  background: #667eea;
  color: #fff;
  border-bottom-right-radius: 4rpx;
}

.message.ai .message-content {
  background: #f0f0f0;
  color: #333;
  border-bottom-left-radius: 4rpx;
}

.typing-indicator {
  font-size: 26rpx;
  color: #999;
  text-align: center;
  padding: 20rpx;
}

.input-area {
  display: flex;
  padding: 20rpx 30rpx;
  background: rgba(255,255,255,0.9);
  gap: 20rpx;
}

.chat-input {
  flex: 1;
  background: #f5f5f5;
  border-radius: 40rpx;
  padding: 20rpx 30rpx;
  font-size: 30rpx;
}

.send-btn {
  background: #667eea;
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 30rpx;
  border: none;
}

.actions {
  display: flex;
  justify-content: center;
  gap: 30rpx;
  padding: 20rpx 30rpx 40rpx;
  background: rgba(255,255,255,0.9);
}

.action-btn {
  background: linear-gradient(135deg, #f093fb 0%, #f5576c 100%);
  color: #fff;
  padding: 20rpx 40rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  border: none;
}

.end-btn {
  background: linear-gradient(135deg, #fa709a 0%, #fee140 100%);
}
