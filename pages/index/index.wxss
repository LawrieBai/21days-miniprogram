.container {
  min-height: 100vh;
  background: linear-gradient(135deg, #ff9a9e 0%, #fecfef 50%, #fecfef 100%);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 40rpx;
}

.cover-page {
  text-align: center;
}

.title {
  font-size: 120rpx;
  font-weight: bold;
  color: #fff;
  text-shadow: 4rpx 4rpx 8rpx rgba(0,0,0,0.2);
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 48rpx;
  color: #fff;
  margin-bottom: 40rpx;
}

.desc {
  font-size: 32rpx;
  color: rgba(255,255,255,0.9);
  margin-bottom: 80rpx;
}

.start-btn {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  padding: 30rpx 80rpx;
  border-radius: 50rpx;
  font-size: 36rpx;
  font-weight: bold;
  border: none;
  box-shadow: 0 8rpx 20rpx rgba(102, 126, 234, 0.4);
}

.tips {
  margin-top: 60rpx;
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
}
